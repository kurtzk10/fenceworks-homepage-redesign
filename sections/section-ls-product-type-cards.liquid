{% if section.index > 2 or section.location == 'footer' %}
  <link
    rel="stylesheet"
    href="{{ 'section-ls-product-type-cards.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
  <noscript>
    {{ 'section-ls-product-type-cards.css' | asset_url | stylesheet_tag }}
  </noscript>
{% else %}
  {{ 'section-ls-product-type-cards.css' | asset_url | stylesheet_tag }}
{% endif %}

{% if section.index > 2 %}
  <link
    rel="stylesheet"
    href="{{ 'component-media-carousel.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
  <noscript>
    {{ 'component-media-carousel.css' | asset_url | stylesheet_tag }}
  </noscript>
{% else %}
  {{ 'component-media-carousel.css' | asset_url | stylesheet_tag }}
{% endif %}
<script src="{{ 'media-carousel.js' | asset_url }}" type="module"></script>

<section
  class="
    section
    section--padded
    section--ls-product-type-cards
    section--{{ section.id }}
    {% if section.settings.section_bottom_margin %}section--mb-0{% endif %}
  "
  data-section-id="{{ section.id }}"
  data-section-type="ls-product-type-cards"
  style="
    --space-top: {{ section.settings.padding_top }}px;
    --space-bottom: {{ section.settings.padding_bottom }}px;
    --lsptc-section-bg: {{ section.settings.section_bg }};
    --lsptc-card-bg: {{ section.settings.card_bg }};
    --lsptc-card-radius: {{ section.settings.card_radius }}px;
    --lsptc-grid-gap: {{ section.settings.grid_gap }}px;
    --lsptc-eyebrow-color: {{ section.settings.eyebrow_color }};
    --lsptc-heading-color: {{ section.settings.heading_color }};
    --lsptc-desc-color: {{ section.settings.desc_color }};
    --lsptc-card-title-color: {{ section.settings.card_title_color }};
    --lsptc-card-text-color: {{ section.settings.card_text_color }};
    --lsptc-spec-icon-bg: {{ section.settings.spec_icon_bg }};
    --lsptc-spec-label-color: {{ section.settings.spec_label_color }};
    --lsptc-spec-value-color: {{ section.settings.spec_value_color }};
    --lsptc-btn-bg: {{ section.settings.btn_bg }};
    --lsptc-btn-text: {{ section.settings.btn_text_color }};
    --lsptc-image-height: {{ section.settings.image_height }}px;
  "
>
  <div class="lsptc__outer">
    <div class="container container--{{ section.settings.section_width }}">

      {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.description != blank -%}
        <div class="lsptc__header">
          {%- if section.settings.eyebrow != blank -%}
            <p class="lsptc__eyebrow">{{ section.settings.eyebrow | escape }}</p>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="lsptc__heading">{{ section.settings.heading }}</h2>
          {%- endif -%}
          {%- if section.settings.description != blank -%}
            <div class="lsptc__desc rte">{{ section.settings.description }}</div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <media-carousel
          data-speed="500"
          data-loop="false"
          data-pagination="true"
          data-space-between="16"
          data-navigation="false"
          data-breakpoint-max="tab"
        >
          <media-carousel-slider>
            <media-carousel-wrapper class="lsptc__grid">
              {%- for block in section.blocks -%}
                <media-carousel-slide
                  class="lsptc__card-wrap block--{{ block.id }}{% if forloop.last %} lsptc__card-wrap--last{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  <div class="lsptc__card">

                    {%- if block.settings.image != blank -%}
                      <div class="lsptc__card-img-wrap">
                        {% render 'image',
                          image: block.settings.image,
                          additional_classes: 'lsptc__card-img',
                          image_ratio: 'natural',
                          image_srcset_widths: '300, 480, 600',
                          image_sizes: '(min-width: 990px) 33vw, 80vw',
                          loading: 'lazy',
                          alt_string: block.settings.title | escape
                        %}
                      </div>
                    {%- else -%}
                      <div class="lsptc__card-img-wrap lsptc__card-img-wrap--empty"></div>
                    {%- endif -%}

                    <div class="lsptc__card-body">

                      {%- unless block.settings.title == blank -%}
                        <h3 class="lsptc__card-title">{{ block.settings.title | escape }}</h3>
                      {%- endunless -%}

                      {%- unless block.settings.description == blank -%}
                        <p class="lsptc__card-desc">{{ block.settings.description | escape }}</p>
                      {%- endunless -%}

                      {%- assign has_specs = false -%}
                      {%- for i in (1..5) -%}
                        {%- assign _spec_label_key = 'spec_' | append: i | append: '_label' -%}
                        {%- if block.settings[_spec_label_key] != blank -%}
                          {%- assign has_specs = true -%}
                        {%- endif -%}
                      {%- endfor -%}

                      {%- if has_specs -%}
                        <div class="lsptc__specs">
                          {%- for i in (1..5) -%}
                            {%- assign _spec_label_key = 'spec_' | append: i | append: '_label' -%}
                            {%- assign _spec_value_key = 'spec_' | append: i | append: '_value' -%}
                            {%- assign _spec_icon_key  = 'spec_' | append: i | append: '_icon' -%}
                            {%- assign _spec_label = block.settings[_spec_label_key] -%}
                            {%- assign _spec_value = block.settings[_spec_value_key] -%}
                            {%- assign _spec_icon  = block.settings[_spec_icon_key] -%}

                            {%- if _spec_label != blank -%}
                              <div class="lsptc__spec-item">
                                <div class="lsptc__spec-icon-wrap">
                                  {%- if _spec_icon != blank -%}
                                    {% render 'image',
                                      image: _spec_icon,
                                      additional_classes: 'lsptc__spec-icon-img',
                                      image_ratio: 'natural',
                                      image_srcset_widths: '80, 120',
                                      image_sizes: '40px',
                                      loading: 'lazy',
                                      alt_string: ''
                                    %}
                                  {%- else -%}
                                    <span class="lsptc__spec-icon-placeholder" aria-hidden="true"></span>
                                  {%- endif -%}
                                </div>

                                <div class="lsptc__spec-content">
                                  <p class="lsptc__spec-label">{{ _spec_label | escape }}</p>
                                  {%- if _spec_value != blank -%}
                                    <div class="lsptc__spec-rte">{{ _spec_value }}</div>
                                  {%- endif -%}
                                </div>
                              </div>
                            {%- endif -%}
                          {%- endfor -%}
                        </div>
                      {%- endif -%}

                      {%- unless block.settings.btn_label == blank -%}
                        {%- assign _btn_link = block.settings.btn_link | default: '#' -%}
                        <a href="{{ _btn_link }}" class="lsptc__card-btn">
                          {{- block.settings.btn_label | escape -}}
                        </a>
                      {%- endunless -%}

                    </div>
                  </div>
                </media-carousel-slide>
              {%- endfor -%}
            </media-carousel-wrapper>
          </media-carousel-slider>

          {%- if section.blocks.size > 1 -%}
            <media-carousel-pagination
              class="media-carousel__pagination swiper-pagination js-carousel-pagination"
              hidden
            ></media-carousel-pagination>
          {%- endif -%}
        </media-carousel>
      {%- else -%}
        <div class="placeholder-noblocks">
          {{ 'homepage.onboarding.no_content' | t }}
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
