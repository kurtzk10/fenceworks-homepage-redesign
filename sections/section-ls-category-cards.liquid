{% if section.index > 2 or section.location == 'footer' %}
  <link
    rel="stylesheet"
    href="{{ 'section-ls-category-cards.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
  <noscript>
    {{ 'section-ls-category-cards.css' | asset_url | stylesheet_tag }}
  </noscript>
{% else %}
  {{ 'section-ls-category-cards.css' | asset_url | stylesheet_tag }}
{% endif %}

<section
  class="
    section
    section--padded
    section--ls-category-cards
    section--{{ section.id }}
    {% if section.settings.section_bottom_margin %}section--mb-0{% endif %}
  "
  data-section-id="{{ section.id }}"
  data-section-type="ls-category-cards"
  style="
    --space-top: {{ section.settings.padding_top }}px;
    --space-bottom: {{ section.settings.padding_bottom }}px;
    --lscg-section-bg: {{ section.settings.section_bg }};
    --lscg-card-bg: {{ section.settings.card_bg }};
    --lscg-card-hover-bg: {{ section.settings.card_hover_bg }};
    --lscg-card-radius: {{ section.settings.card_radius }}px;
    --lscg-label-color: {{ section.settings.label_color }};
    --lscg-eyebrow-color: {{ section.settings.eyebrow_color }};
    --lscg-heading-color: {{ section.settings.heading_color }};
    --lscg-heading-accent-color: {{ section.settings.heading_accent_color }};
    --lscg-card-height: {{ section.settings.card_height }}px;
    --lscg-image-overlap: {{ section.settings.image_overlap }}px;
    --lscg-grid-gap: {{ section.settings.grid_gap }}px;
  "
>
  <div class="lscg__outer">
    <div class="container container--{{ section.settings.section_width }}">

      {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
        <div class="lscg__header">
          {%- if section.settings.eyebrow != blank -%}
            <p class="lscg__eyebrow">{{ section.settings.eyebrow | escape }}</p>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="lscg__heading">{{ section.settings.heading }}</h2>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="lscg__grid">
          {%- for block in section.blocks -%}
            <div
              class="lscg__card-wrap block--{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              {%- assign card_link = block.settings.link | default: '#' -%}
              <a href="{{ card_link }}" class="lscg__card">
                <div class="lscg__card-inner">

                  <div class="lscg__card-imgs">
                    {%- assign first_slot_shown = false -%}

                    {%- if block.settings.image_1 != blank -%}
                      <div class="lscg__card-img-slot lscg__card-img-slot--active">
                        {% render 'image',
                          image: block.settings.image_1,
                          additional_classes: 'lscg__img',
                          image_ratio: 'natural',
                          image_srcset_widths: '300, 480, 600',
                          image_sizes: '(min-width: 990px) 25vw, 50vw',
                          loading: 'lazy',
                          alt_string: block.settings.label | escape
                        %}
                      </div>
                      {%- assign first_slot_shown = true -%}
                    {%- endif -%}

                    {%- if block.settings.image_2 != blank -%}
                      <div class="lscg__card-img-slot{% unless first_slot_shown %} lscg__card-img-slot--active{% endunless %}">
                        {% render 'image',
                          image: block.settings.image_2,
                          additional_classes: 'lscg__img',
                          image_ratio: 'natural',
                          image_srcset_widths: '300, 480, 600',
                          image_sizes: '(min-width: 990px) 25vw, 50vw',
                          loading: 'lazy',
                          alt_string: block.settings.label | escape
                        %}
                      </div>
                      {%- assign first_slot_shown = true -%}
                    {%- endif -%}

                    {%- if block.settings.image_3 != blank -%}
                      <div class="lscg__card-img-slot{% unless first_slot_shown %} lscg__card-img-slot--active{% endunless %}">
                        {% render 'image',
                          image: block.settings.image_3,
                          additional_classes: 'lscg__img',
                          image_ratio: 'natural',
                          image_srcset_widths: '300, 480, 600',
                          image_sizes: '(min-width: 990px) 25vw, 50vw',
                          loading: 'lazy',
                          alt_string: block.settings.label | escape
                        %}
                      </div>
                    {%- endif -%}

                    {%- unless first_slot_shown -%}
                      <div class="lscg__card-img-slot lscg__card-img-slot--active lscg__card-img-slot--placeholder">
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg lscg__img' }}
                      </div>
                    {%- endunless -%}
                  </div>

                  {%- unless block.settings.label == blank -%}
                    <span class="lscg__card-label">{{ block.settings.label | escape }}</span>
                  {%- endunless -%}

                </div>
              </a>
            </div>
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="placeholder-noblocks">
          {{ 'homepage.onboarding.no_content' | t }}
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

<script src="{{ 'section-ls-category-cards.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "LS Category Cards",
  "class": "js-section__ls-category-cards",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Explore Categories"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "info": "Wrap text in <em> tags for the accent color.",
      "default": "<p>ONE-STOP SOLUTIONS<br>BY <em>THE GUY ON 41</em></p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "default": "large",
      "options": [
        { "label": "Default", "value": "large" },
        { "label": "Narrow", "value": "small" },
        { "label": "Wide", "value": "full" }
      ]
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Gap between cards",
      "unit": "px",
      "min": 8,
      "max": 40,
      "step": 4,
      "default": 16
    },
    {
      "type": "header",
      "content": "Card sizing"
    },
    {
      "type": "range",
      "id": "card_height",
      "label": "Card height (gray box)",
      "unit": "px",
      "min": 120,
      "max": 320,
      "step": 10,
      "default": 190
    },
    {
      "type": "range",
      "id": "image_overlap",
      "label": "Image overflow above card",
      "unit": "px",
      "min": 40,
      "max": 160,
      "step": 10,
      "default": 100
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "unit": "px",
      "min": 0,
      "max": 32,
      "step": 2,
      "default": 16
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#E9EBEC"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#9EA6AC"
    },
    {
      "type": "color",
      "id": "card_hover_bg",
      "label": "Card hover background",
      "default": "#F78B2A"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Card label text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow text",
      "default": "#F78B2A"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading text",
      "default": "#1B2733"
    },
    {
      "type": "color",
      "id": "heading_accent_color",
      "label": "Heading accent (em) text",
      "default": "#F78B2A"
    },
    {
      "type": "header",
      "content": "Padding and margin"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "unit": "px",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "unit": "px",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "checkbox",
      "id": "section_bottom_margin",
      "label": "Reduce bottom margin",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "category_card",
      "name": "Category card",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Image 1"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Image 2"
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Image 3"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LS Category Cards",
      "blocks": [
        { "type": "category_card", "settings": { "label": "Fences" } },
        { "type": "category_card", "settings": { "label": "Playsets" } },
        { "type": "category_card", "settings": { "label": "Basketball Hoops" } },
        { "type": "category_card", "settings": { "label": "Trampolines" } }
      ]
    }
  ]
}
{% endschema %}
