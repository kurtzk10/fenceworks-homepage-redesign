{%- assign grid_items = section.blocks | where: 'type', 'grid_item' -%}
{% if section.index > 2 or section.location == 'footer' %}
  <link
    rel="stylesheet"
    href="{{ 'section-tabbed-column-grid.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
  <noscript>
    {{ 'section-tabbed-column-grid.css' | asset_url | stylesheet_tag }}
  </noscript>
{% else %}
  {{ 'section-tabbed-column-grid.css' | asset_url | stylesheet_tag }}
{% endif %}

{%- liquid
  assign columns_desktop = section.settings.grid_columns_desktop
  assign columns_mobile = section.settings.grid_columns_mobile
  assign initial_per_tab = section.settings.initial_items_per_tab
  assign tab_keys = 'main,1,2,3' | split: ','
-%}

{% if grid_items.size > 0 %}
<section
  class="
    section
    section--padded
    section--{{ section.id }}
    section--tabbed-column-grid
    {% if section.settings.section_bottom_margin %}
      section--mb-0
    {% else %}
      section--mb-s
    {% endif %}
  "
  data-section-id="{{ section.id }}"
  data-section-type="tabbed-column-grid"
  data-initial-per-tab="{{ initial_per_tab }}"
  style="
    --space-top: {{ section.settings.padding_top }}px;
    --space-bottom: {{ section.settings.padding_bottom }}px;
    --tcg-section-bg: {{ section.settings.section_bg }};
    --tcg-content-bg: {{ section.settings.content_bg }};
    --tcg-content-radius: {{ section.settings.content_border_radius }}px;
    --tcg-tab-active-bg: {{ section.settings.tab_active_bg }};
    --tcg-tab-inactive-bg: {{ section.settings.tab_inactive_bg }};
    --tcg-tab-text: {{ section.settings.tab_text_color }};
    --tcg-heading-color: {{ section.settings.heading_color }};
    --tcg-text-color: {{ section.settings.text_color }};
    --tcg-accent-color: {{ section.settings.accent_color }};
    --tcg-contact-bg: {{ section.settings.contact_bg }};
    --tcg-contact-border: {{ section.settings.contact_border_color }};
    --tcg-contact-text: {{ section.settings.contact_text_color }};
    --tcg-contact-link: {{ section.settings.contact_link_color }};
    --tcg-grid-cols-desktop: {{ columns_desktop }};
    --tcg-grid-cols-mobile: {{ columns_mobile }};
    --tcg-grid-gap: {{ section.settings.grid_spacing }}px;
    --tcg-btn-bg: {{ section.settings.button_bg }};
    --tcg-btn-text: {{ section.settings.button_text_color }};
    --tcg-btn-radius: {{ section.settings.button_border_radius }}px;
    --tcg-loadmore-bg: {{ section.settings.load_more_bg }};
    --tcg-loadmore-text: {{ section.settings.load_more_text_color }};
    --tcg-loadmore-border: {{ section.settings.load_more_border_color }};
    --tcg-loadmore-radius: {{ section.settings.load_more_border_radius }}px;
    --tcg-heading-size: {{ section.settings.heading_size }}px;
    --tcg-tab-heading-size: {{ section.settings.tab_heading_size }}px;
  "
>
  <div class="tcg__outer">
    <div class="container container--{{ section.settings.section_width }}">
      {%- if section.settings.title != blank or section.settings.intro != blank -%}
        <div class="tcg__header section__title section__title--center {% unless section.settings.intro == blank %} section__title--desc{% endunless %}">
          {%- unless section.settings.title == blank -%}
            <h2 class="tcg__main-title section__title-text">{{ section.settings.title | escape }}</h2>
          {%- endunless -%}
          {%- unless section.settings.intro == blank -%}
            <div class="tcg__intro section__title-desc rte">{{ section.settings.intro }}</div>
          {%- endunless -%}
        </div>
      {%- endif -%}

      <div class="tcg__content-box">
        <div class="tcg__tabs-wrapper" role="tablist" aria-label="Tabs">
        <div class="tcg__tabs" role="tablist" aria-label="Tabs">
          {%- assign first_visible_tab = true -%}
          {% for i in tab_keys %}
            {%- assign label_key = 'tab_' | append: i | append: '_label' -%}
            {%- assign label = section.settings[label_key] -%}
            {%- if label != blank -%}
              <button
                type="button"
                class="tcg__tab {% if first_visible_tab %}tcg__tab--active{% endif %}"
                role="tab"
                aria-selected="{% if first_visible_tab %}true{% else %}false{% endif %}"
                aria-controls="tcg-panel-{{ section.id }}-{{ i }}"
                id="tcg-tab-{{ section.id }}-{{ i }}"
                data-tab="{{ i }}"
              >
                {{ label | escape }}
              </button>
              {%- assign first_visible_tab = false -%}
            {%- endif -%}
          {% endfor %}
          </div>
        </div>
     
        {%- assign first_visible_panel = true -%}
        {% for i in tab_keys %}
          {%- assign label_key = 'tab_' | append: i | append: '_label' -%}
          {%- assign subtitle_key = 'tab_' | append: i | append: '_subtitle' -%}
          {%- assign title_key = 'tab_' | append: i | append: '_title' -%}
          {%- assign desc_key = 'tab_' | append: i | append: '_description' -%}

          {%- if section.settings[label_key] != blank -%}
          <div
            id="tcg-panel-{{ section.id }}-{{ i }}"
            class="tcg__panel {% if first_visible_panel %}tcg__panel--active{% endif %}"
            role="tabpanel"
            aria-labelledby="tcg-tab-{{ section.id }}-{{ i }}"
            data-tab="{{ i }}"
            {% unless first_visible_panel %}hidden{% endunless %}
          >
            <div class="tcg__panel-inner">
              {%- if section.settings[subtitle_key] != blank -%}
                <p class="tcg__tab-subtitle">{{ section.settings[subtitle_key] | escape }}</p>
              {%- endif -%}
              {%- if section.settings[title_key] != blank -%}
                <h3 class="tcg__tab-title">{{ section.settings[title_key] | escape }}</h3>
              {%- endif -%}
              {%- if section.settings[desc_key] != blank -%}
                <div class="tcg__tab-desc rte">{{ section.settings[desc_key] }}</div>
              {%- endif -%}

              {%- if section.settings.show_contact_callout -%}
                {%- if section.settings.contact_text != blank -%}
                <div class="tcg__contact">
                   {{ section.settings.contact_text }}
                </div>
                {%- endif -%}
              {%- endif -%}

              <div class="tcg__grid" data-tab="{{ i }}">
                {%- assign count = 0 -%}
                {%- assign tab_id_str = i | append: '' -%}
                {%- for block in grid_items -%}
                  {%- if block.settings.tab == tab_id_str -%}
                    {%- assign count = count | plus: 1 -%}
                    <div
                      class="tcg__grid-item {% if count > initial_per_tab %}tcg__grid-item--hidden{% endif %}"
                      data-tab-index="{{ count }}"
                      {{ block.shopify_attributes }}
                    >
                      <div class="tcg__card">
                        {%- if block.settings.image != blank -%}
                          <div class="tcg__card-media">
                            <a href="{{ block.settings.button_link | default: '#' }}" class="tcg__card-media-link">
                              {% render 'image',
                                image: block.settings.image,
                                alt_string: block.settings.title | escape,
                                additional_classes: 'tcg__card-img',
                                image_ratio: 'natural',
                                image_srcset_widths: '360, 540, 720, 900, 1080',
                                image_sizes: '(min-width: 768px) 50vw, 100vw',
                                render_skeleton: true,
                                loading: 'lazy'
                              %}
                            </a>
                          </div>
                        {%- else -%}
                          <div class="tcg__card-media">
                            <span class="tcg__card-placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</span>
                          </div>
                        {%- endif -%}
                        <div class="tcg__card-body">
                          {%- unless block.settings.title == blank -%}
                            <h4 class="tcg__card-title">{{ block.settings.title | escape }}</h4>
                          {%- endunless -%}
                          {%- unless block.settings.price == blank -%}
                            <p class="tcg__card-price">{{ block.settings.price | escape }}</p>
                          {%- endunless -%}
                          {%- unless block.settings.button_text == blank -%}
                            <a
                              href="{{ block.settings.button_link | default: '#' }}"
                              class="tcg__card-btn"
                            >
                              {{ block.settings.button_text | escape }}
                            </a>
                          {%- endunless -%}
                        </div>
                      </div>
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>

              {%- assign tab_item_count = 0 -%}
              {%- for block in grid_items -%}
                {%- if block.settings.tab == tab_id_str -%}
                  {%- assign tab_item_count = tab_item_count | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}

              {%- if section.settings.show_load_more and tab_item_count > initial_per_tab -%}
                {%- assign load_more_key = 'tab_' | append: i | append: '_load_more_text' -%}
                {%- assign load_more_label = section.settings[load_more_key] -%}
                {%- if load_more_label == blank -%}
                  {%- assign tab_label = section.settings[label_key] -%}
                  {%- assign load_more_label = 'Load more' | append: ' ' | append: tab_label -%}
                {%- endif -%}
                <div class="tcg__load-more-wrap">
                  <button
                    type="button"
                    class="tcg__load-more"
                    data-load-more-tab="{{ i }}"
                  >
                    {{ load_more_label }}
                  </button>
                </div>
              {%- endif -%}
            </div>
          </div>
          {%- assign first_visible_panel = false -%}
          {%- endif -%}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script src="{{ 'section-tabbed-column-grid.js' | asset_url }}" type="module"></script>
{% else %}
  <div class="placeholder-noblocks">
    {{ 'homepage.onboarding.no_content' | t }}
  </div>
{% endif %}

