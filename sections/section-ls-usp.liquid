{% if section.index > 2 or section.location == 'footer' %}
  <link
    rel="stylesheet"
    href="{{ 'section-ls-usp.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
  <noscript>
    {{ 'section-ls-usp.css' | asset_url | stylesheet_tag }}
  </noscript>
{% else %}
  {{ 'section-ls-usp.css' | asset_url | stylesheet_tag }}
{% endif %}

<section
  class="
    section
    section--padded
    section--ls-usp
    section--{{ section.id }}
    {% if section.settings.section_bottom_margin %}section--mb-0{% endif %}
  "
  data-section-id="{{ section.id }}"
  data-section-type="ls-usp"
  style="
    --space-top: {{ section.settings.padding_top }}px;
    --space-bottom: {{ section.settings.padding_bottom }}px;
    --ls-usp-bg: {{ section.settings.background_color }};
    --ls-usp-icon-bg: {{ section.settings.icon_bg_color }};
    --ls-usp-icon-color: {{ section.settings.icon_color }};
  "
>
  <div class="ls-usp">
    <div class="container container--{{ section.settings.container_width }}">
      {%- if section.blocks.size > 0 -%}
        <div class="ls-usp__grid">
          {% for block in section.blocks %}
            <div
              class="ls-usp__card block--{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.icon_image != blank -%}
                <div class="ls-usp__card-icon-wrap">
                  {% render 'image',
                    image: block.settings.icon_image,
                    additional_classes: 'ls-usp__card-icon-img',
                    image_ratio: 'natural',
                    image_default_width: 64,
                    alt_string: block.settings.title | strip_html | default: block.settings.icon_image.alt
                  %}
                </div>
              {%- endif -%}
              <div class="ls-usp__card-inner">
              <div class="ls-usp__card-content">
                {%- unless block.settings.title == blank -%}
                  <h3 class="ls-usp__card-title">{{ block.settings.title | escape }}</h3>
                {%- endunless -%}
                {%- unless block.settings.subtitle == blank -%}
                  <div class="ls-usp__card-subtitle rte">{{ block.settings.subtitle }}</div>
                {%- endunless -%}
              </div>
            </div>
            </div>
          {% endfor %}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% if section.blocks.size == 0 %}
  <div class="placeholder-noblocks">
    {{ 'homepage.onboarding.no_content' | t }}
  </div>
{% endif %}

{% schema %}
{
  "name": "LS USP",
  "class": "js-section__ls-usp",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Section width",
      "default": "small",
      "options": [
        {
          "label": "Default",
          "value": "large"
        },
        {
          "label": "Narrow",
          "value": "small"
        },
        {
          "label": "Wide",
          "value": "full"
        }
      ]
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "icon_bg_color",
      "label": "Icon background",
      "default": "#fff3e0"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#e65100"
    },
    {
      "type": "header",
      "content": "Padding and margin"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "unit": "px",
      "min": 0,
      "max": 120,
      "step": 3,
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "unit": "px",
      "min": 0,
      "max": 120,
      "step": 3,
      "default": 48
    },
    {
      "type": "checkbox",
      "id": "section_bottom_margin",
      "label": "Reduce bottom margin",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "ls_usp_item",
      "name": "LS USP item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "FAMILY-OWNED & LOCAL"
        },
        {
          "type": "richtext",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "<p>Your neighbors, not a national chain. We live here too.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LS USP",
      "blocks": [
        {
          "type": "ls_usp_item",
          "settings": {
            "title": "FAMILY-OWNED & LOCAL",
            "subtitle": "<p>Your neighbors, not a national chain. We live here too.</p>"
          }
        },
        {
          "type": "ls_usp_item",
          "settings": {
            "title": "ONE-STOP SOLUTION",
            "subtitle": "<p>Sales, installation, maintenance. All under one roof.</p>"
          }
        },
        {
          "type": "ls_usp_item",
          "settings": {
            "title": "ESTABLISHED IN 1967",
            "subtitle": "<p>Nearly 60 years of trusted service to Chicagoland families</p>"
          }
        },
        {
          "type": "ls_usp_item",
          "settings": {
            "title": "PREMIUM STANDARDS",
            "subtitle": "<p>Professional crews delivering high-end service, every time</p>"
          }
        },
        {
          "type": "ls_usp_item",
          "settings": {
            "title": "CHICAGOLAND EXPERTS",
            "subtitle": "<p>Deep local knowledge of permits, weather, & local styles</p>"
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["*"]
  }
}
{% endschema %}
