{% if section.index > 2 and section.location != 'header' %}
  <link
    rel="stylesheet"
    href="{{ 'section-featured-in.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
  <noscript>
    {{ 'section-featured-in.css' | asset_url | stylesheet_tag }}
  </noscript>
{% else %}
  {{ 'section-featured-in.css' | asset_url | stylesheet_tag }}
{% endif %}


{% liquid
  assign title = section.settings.title | default: 'FEATURED IN'
  assign schema_keyword = section.settings.schema_keyword | default: 'LS'
  assign sizes_grid = '(min-width: 981px) calc((100vw - 120px) / 6), (min-width: 769px) calc((100vw - 80px) / 4), 140px'
  assign sizes_marquee = '140px'
%}

<section
  class="
    section
    section--padded
    section--{{ section.id }}
    section--featured-in
    {% if section.settings.divider_top %}section-divider--top{% endif %}
    {% if section.settings.divider_bottom %}section-divider--bottom{% endif %}
    {% if section.settings.section_bottom_margin %}section--mb-0{% endif %}
  "
  data-section-id="{{ section.id }}"
  data-section-type="featured-in"
  data-schema-keyword="{{ schema_keyword }}"
  style="
    --space-top: {{ section.settings.padding_top }}px;
    --space-bottom: {{ section.settings.padding_bottom }}px;
    --background-color: {{ section.settings.color_bg }};
    --featured-in-heading-color: {{ section.settings.color_heading }};
    --featured-in-logo-opacity: {{ section.settings.logo_opacity }}%;
    --featured-in-marquee-duration: {{ section.settings.marquee_speed }}s;
  "
>
  <div class="featured-in container container--{{ section.settings.content_width }}">
    {% if title != blank %}
      <h2 class="featured-in__title js-animate-single" data-animation-displacement="0">
        {{ title | escape }}
      </h2>
    {% endif %}

    {% comment %} Desktop: grid of logos {% endcomment %}
    <div class="featured-in__grid">
      <div class="featured-in__grid-inner">
        {% for block in section.blocks %}
          <div class="featured-in__item" {{ block.shopify_attributes }}>
            {% unless block.settings.link == blank %}
              <a href="{{ block.settings.link }}" class="featured-in__item-link">
            {% endunless %}
            {% if block.settings.image != blank %}
              {% render 'image',
                image: block.settings.image,
                alt_string: block.settings.image.alt | default: block.settings.title,
                additional_classes: 'featured-in__img',
                image_default_width: '240',
                image_ratio: 'natural',
                image_srcset_widths: '120, 180, 240, 300, 360',
                image_sizes: sizes_grid,
                render_skeleton: true,
                loading: 'lazy'
              %}
            {% else %}
              <div class="featured-in__placeholder">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {% endif %}
            {% unless block.settings.link == blank %}
              </a>
            {% endunless %}
          </div>
        {% endfor %}
      </div>
    </div>

    {% comment %} Mobile: single row auto-scroll marquee {% endcomment %}
    <div class="featured-in__marquee">
      <div class="featured-in__marquee-track">
        {% for i in (1..2) %}
          {% for block in section.blocks %}
            <div class="featured-in__marquee-item">
              {% unless block.settings.link == blank %}
                <a href="{{ block.settings.link }}" class="featured-in__item-link">
              {% endunless %}
              {% if block.settings.image != blank %}
                {% render 'image',
                  image: block.settings.image,
                  alt_string: block.settings.image.alt | default: block.settings.title,
                  additional_classes: 'featured-in__img',
                  image_default_width: '240',
                  image_ratio: 'natural',
                  image_srcset_widths: '120, 180, 240',
                  image_sizes: sizes_marquee,
                  render_skeleton: false,
                  loading: 'lazy'
                %}
              {% else %}
                <div class="featured-in__placeholder">
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {% endif %}
              {% unless block.settings.link == blank %}
                </a>
              {% endunless %}
            </div>
          {% endfor %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured In [LS]",
  "class": "js-section__featured-in",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "FEATURED IN"
    },
    {
      "type": "text",
      "id": "schema_keyword",
      "label": "Schema keyword (section name)",
      "default": "LS",
      "info": "Keyword used to identify this section in schema (e.g. LS)."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "default": "large",
      "options": [
        { "value": "small", "label": "Narrow" },
        { "value": "large", "label": "Default" },
        { "value": "wide", "label": "Wide" }
      ]
    },
    {
      "type": "header",
      "content": "Mobile marquee"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "label": "Scroll speed",
      "min": 15,
      "max": 60,
      "step": 5,
      "default": 30,
      "unit": "s"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Background"
    },
    {
      "type": "color",
      "id": "color_heading",
      "label": "Heading color",
      "default": "#4a4a4a"
    },
    {
      "type": "range",
      "id": "logo_opacity",
      "label": "Logo opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 100,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Borders and spacing"
    },
    {
      "type": "checkbox",
      "id": "divider_top",
      "label": "Show top border",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "divider_bottom",
      "label": "Show bottom border",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "unit": "px",
      "min": 0,
      "max": 120,
      "step": 3,
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "unit": "px",
      "min": 0,
      "max": 120,
      "step": 3,
      "default": 36
    },
    {
      "type": "checkbox",
      "id": "section_bottom_margin",
      "label": "Reduce bottom margin",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Alt text (optional)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured In [LS]",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["*"]
  }
}
{% endschema %}
