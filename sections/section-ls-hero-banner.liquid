{% if section.blocks.size > 0 %}
  {% if section.index > 2 or section.location == 'footer' %}
    <link
      rel="stylesheet"
      href="{{ 'component-media-carousel.css' | asset_url }}"
      media="print"
      onload="this.media='all'"
    >
    <link
      rel="stylesheet"
      href="{{ 'section-ls-hero-banner.css' | asset_url }}"
      media="print"
      onload="this.media='all'"
    >
    <noscript>
      {{ 'component-media-carousel.css' | asset_url | stylesheet_tag }}
      {{ 'section-ls-hero-banner.css' | asset_url | stylesheet_tag }}
    </noscript>
  {% else %}
    {{ 'component-media-carousel.css' | asset_url | stylesheet_tag }}
    {{ 'section-ls-hero-banner.css' | asset_url | stylesheet_tag }}
  {% endif %}
  {{ 'component-ls-button.css' | asset_url | stylesheet_tag }}
  <style>
    .ls-hero-banner.is-loading {
      display: block;
      position: relative;
      overflow: hidden;
      width: 100%;
    }
    .ls-hero-banner.is-loading media-carousel-slider {
      position: absolute;
      width: 100%;
      height: 100%;
      top: 0;
      left: 0;
    }
    .ls-hero-banner.is-loading::before {
      content: '';
      display: block;
      float: left;
      position: relative;
      width: 100%;
    }
    .ls-hero-banner.ls-hero-banner--small.is-loading::before { padding-bottom: 40%; }
    .ls-hero-banner.ls-hero-banner--medium.is-loading::before { padding-bottom: 50%; }
    .ls-hero-banner.ls-hero-banner--large.is-loading::before { padding-bottom: 62.5%; }
    .ls-hero-banner.ls-hero-banner--full-screen.is-loading::before {
      height: calc(var(--window-height) - var(--announcement-height) - var(--header-section-height));
      min-height: 400px;
    }
    .ls-hero-banner.is-loading media-carousel-slide:not(:first-of-type) { display: none; }
    .ls-hero-banner.is-loading .home-carousel__nav { display: none; }
    @media screen and (max-width: 980px) {
      .ls-hero-banner.ls-hero-banner--small.is-loading::before { padding-bottom: 100%; }
      .ls-hero-banner.ls-hero-banner--medium.is-loading::before { padding-bottom: 125%; }
      .ls-hero-banner.ls-hero-banner--large.is-loading::before { padding-bottom: 140%; }
    }
  </style>
  <section
    class="section section--{{ section.id }} {% if section.settings.slideshow_width == 'full' %} section--full section--full-mobile{% endif %}{% if section.settings.section_bottom_margin %}{% if section.settings.slideshow_width == 'contained' %} section--mb-m{% else %} section--mb-0{% endif %}{% endif %}"
    data-section-id="{{ section.id }}"
    data-section-type="ls-hero-banner"
  >
    {% if section.settings.slideshow_width == 'contained' %}<div class="container">{% endif %}

    {%- if section.index == 1 -%}
      <link rel="modulepreload" href="{{ 'media-carousel.js' | asset_url }}">
      <link rel="modulepreload" href="{{ 'swiper.lib.js' | asset_url }}">
    {%- endif -%}

    <script src="{{ 'media-carousel.js' | asset_url }}" type="module"></script>
    <media-carousel
      class="
        home-carousel
        ls-hero-banner
        ls-hero-banner--{{ section.settings.slideshow_height }}
        {% if section.settings.slideshow_width == 'full' %} home-carousel--full {% else %} home-carousel--contained {% endif %}
        {% if section.blocks.size == 1 %} home-carousel--single-slide {% endif %}
        is-loading
      "
      data-fade="true"
      data-speed="400"
      data-space-between="0"
      data-loop="true"
      {% if section.settings.autoplay %}
        data-autoplay="{{ section.settings.autoplay_speed }}000"
      {% endif %}
      {% if section.blocks.size > 1 %}
        data-navigation="true"
        data-pagination="true"
      {% endif %}
      style="--bullet-color: #fff; --swiper-pagination-color: #fff;"
    >
      {%- capture slides -%}
        {% for block in section.blocks %}
          {%- if forloop.first -%}
            {%- capture preview_image -%}
              {%- liquid
                assign loading = 'eager'
                assign fetchpriority = 'auto'
                if section.index == 1
                  assign fetchpriority = 'high'
                elsif section.index > 2
                  assign loading = 'lazy'
                endif
              -%}
              <div
                class="
                  home-carousel__item-wrapper
                  ls-hero-banner__slide-wrapper
                  home-carousel__item-wrapper--{{ block.id }}
                  ls-hero-banner__slide-wrapper--{{ section.settings.slideshow_height }}
                  o-ratio
                "
              >
                <div class="o-ratio__content ls-hero-banner__slide home-carousel__item home-carousel__item--left home-carousel__item--middle home-carousel__item--{{ block.id }}">
                  {% unless block.settings.image == blank %}
                    <picture>
                      <source
                        {% if block.settings.image_mobile %}
                          srcset="{% render 'bgset', image: block.settings.image_mobile %}"
                        {% else %}
                          srcset="{% render 'bgset', image: block.settings.image %}"
                        {% endif %}
                        media="all and (max-width: 980px)"
                      >
                      <source
                        srcset="{% render 'bgset', image: block.settings.image %}"
                        media="all and (min-width: 981px)"
                      >
                      {%- liquid
                        assign class = 'ls-hero-banner__bg home-carousel__bg'
                        assign image_width = 600
                        assign image_height = 600 | divided_by: block.settings.image.aspect_ratio | round
                      -%}
                      {%- if block.settings.image_mobile -%}
                        {%- assign skeleton_image_height = 600 | divided_by: block.settings.image_mobile.aspect_ratio | round -%}
                      {%- else -%}
                        {%- assign skeleton_image_height = image_height -%}
                      {%- endif -%}
                      {%- render 'image-skeleton', alt: block.settings.image.alt, width: image_width, height: skeleton_image_height -%}
                      <img
                        class="{{ class }}"
                        src="{{ block.settings.image | image_url: width: 600 }}"
                        width="{{ image_width }}"
                        height="{{ image_height }}"
                        alt="{{ block.settings.image.alt }}"
                        loading="{{ loading }}"
                        fetchpriority="{{ fetchpriority }}"
                        style="--image-position: {{ block.settings.image.presentation.focal_point }}; --image-position-mobile: {% if block.settings.image_mobile %}{{ block.settings.image_mobile.presentation.focal_point }}{% else %}{{ block.settings.image.presentation.focal_point }}{% endif %};"
                      >
                    </picture>
                  {% else %}
                    {% capture current %}{% cycle 1, 2 %}{% endcapture %}
                    {{ 'lifestyle-' | append: current | placeholder_svg_tag: 'placeholder-svg ls-hero-banner__bg' }}
                  {% endunless %}
                  <div class="ls-hero-banner__overlay" aria-hidden="true"></div>
                  <div class="ls-hero-banner__content">
                    {% unless block.settings.title == blank %}
                      <h2 class="ls-hero-banner__title">{{ block.settings.title | escape }}</h2>
                    {% endunless %}
                    {% unless block.settings.text == blank %}
                      <div class="ls-hero-banner__text rte">{{ block.settings.text }}</div>
                    {% endunless %}
                    {% if block.settings.link_title != blank or block.settings.link_title_2 != blank %}
                      <div class="ls-hero-banner__btns">
                        {% if block.settings.link_title != blank %}
                          {% render 'ls-button',
                            label: block.settings.link_title,
                            href: block.settings.link,
                            variant: 'primary-arrow',
                            icon: block.settings.arrow_direction,
                            full_width: true,
                            class: 'ls-hero-banner__cta'
                          %}
                        {% endif %}
                        {% if block.settings.link_title_2 != blank %}
                          <a href="{{ block.settings.link_2 }}" class="ls-hero-banner__btn ls-hero-banner__btn--secondary">{{ block.settings.link_title_2 | escape }}</a>
                        {% endif %}
                      </div>
                    {% endif %}
                    {% if block.settings.rating_value != blank or block.settings.rating_text != blank %}
                      <div class="ls-hero-banner__rating">
                        <span class="ls-hero-banner__stars" aria-hidden="true">{% for i in (1..5) %}{% render 'icon-star', additional_classes: 'ls-hero-banner__star' %}{% endfor %}</span>
                        <span class="ls-hero-banner__rating-text">{% if block.settings.rating_value != blank %}<b>{{ block.settings.rating_value | escape }}</b>{% endif %}{% if block.settings.rating_value != blank and block.settings.rating_text != blank %} {% endif %}{% if block.settings.rating_text != blank %}{{ block.settings.rating_text | escape }}{% endif %}</span>
                      </div>
                    {% endif %}
                  </div>
                  {% if block.settings.floating_cta_title != blank %}
                    <a href="{{ block.settings.floating_cta_link }}" class="ls-hero-banner__floating-cta">{{ block.settings.floating_cta_title | escape }}</a>
                  {% endif %}
                </div>
              </div>
            {%- endcapture -%}
          {%- endif -%}

          <media-carousel-slide class="swiper-slide">
            <div
              class="
                home-carousel__item-wrapper
                ls-hero-banner__slide-wrapper
                home-carousel__item-wrapper--{{ block.id }}
                ls-hero-banner__slide-wrapper--{{ section.settings.slideshow_height }}
                o-ratio
              "
              {{ block.shopify_attributes }}
            >
              <div class="o-ratio__content ls-hero-banner__slide home-carousel__item home-carousel__item--left home-carousel__item--middle home-carousel__item--{{ block.id }}" data-slide-id="{{ forloop.index0 }}">
                {% unless block.settings.image == blank %}
                  <div class="ls-hero-banner__bg-wrapper">
                    <div class="theme-spinner theme-spinner--white"></div>
                    <picture>
                      <source
                        {% if block.settings.image_mobile %}
                          srcset="{% render 'bgset', image: block.settings.image_mobile %}"
                        {% else %}
                          srcset="{% render 'bgset', image: block.settings.image %}"
                        {% endif %}
                        media="all and (max-width: 980px)"
                      >
                      <source
                        srcset="{% render 'bgset', image: block.settings.image %}"
                        media="all and (min-width: 981px)"
                      >
                      {%- liquid
                        assign loading = 'eager'
                        assign fetchpriority = 'auto'
                        if section.index == 1
                          assign fetchpriority = 'high'
                        elsif section.index > 2
                          assign loading = 'lazy'
                        endif
                        assign class = 'ls-hero-banner__bg home-carousel__bg'
                        assign image_width = 600
                        assign image_height = 600 | divided_by: block.settings.image.aspect_ratio | round
                      -%}
                      {%- if block.settings.image_mobile -%}
                        {%- assign skeleton_image_height = 600 | divided_by: block.settings.image_mobile.aspect_ratio | round -%}
                      {%- else -%}
                        {%- assign skeleton_image_height = image_height -%}
                      {%- endif -%}
                      {%- render 'image-skeleton', alt: block.settings.image.alt, width: image_width, height: skeleton_image_height -%}
                      <img
                        class="{{ class }}"
                        src="{{ block.settings.image | image_url: width: 600 }}"
                        width="{{ image_width }}"
                        height="{{ image_height }}"
                        alt="{{ block.settings.image.alt }}"
                        loading="{{ loading }}"
                        fetchpriority="{{ fetchpriority }}"
                        style="--image-position: {{ block.settings.image.presentation.focal_point }}; --image-position-mobile: {% if block.settings.image_mobile %}{{ block.settings.image_mobile.presentation.focal_point }}{% else %}{{ block.settings.image.presentation.focal_point }}{% endif %};"
                      >
                    </picture>
                    <div class="ls-hero-banner__overlay" aria-hidden="true"></div>
                  </div>
                {% else %}
                  <div class="ls-hero-banner__bg ls-hero-banner__bg--placeholder">
                    {% capture current %}{% cycle 1, 2 %}{% endcapture %}
                    {{ 'lifestyle-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                  <div class="ls-hero-banner__overlay" aria-hidden="true"></div>
                {% endunless %}

                <div class="ls-hero-banner__content">
                  {% unless block.settings.title == blank %}
                    <h2 class="ls-hero-banner__title">{{ block.settings.title | escape }}</h2>
                  {% endunless %}
                  {% unless block.settings.text == blank %}
                    <div class="ls-hero-banner__text rte">{{ block.settings.text }}</div>
                  {% endunless %}
                  {% if block.settings.link_title != blank or block.settings.link_title_2 != blank %}
                    <div class="ls-hero-banner__btns">
                      {% if block.settings.link_title != blank %}
                        {% render 'ls-button',
                          label: block.settings.link_title,
                          href: block.settings.link,
                          variant: 'primary-arrow',
                          icon: block.settings.arrow_direction,
                          full_width: true,
                          class: 'ls-hero-banner__cta'
                        %}
                      {% endif %}
                      {% if block.settings.link_title_2 != blank %}
                        <a href="{{ block.settings.link_2 }}" class="ls-hero-banner__btn ls-hero-banner__btn--secondary">{{ block.settings.link_title_2 | escape }}</a>
                      {% endif %}
                    </div>
                  {% endif %}
                  {% if block.settings.rating_value != blank or block.settings.rating_text != blank %}
                    <div class="ls-hero-banner__rating">
                      <span class="ls-hero-banner__stars" aria-hidden="true">{% for i in (1..5) %}{% render 'icon-star', additional_classes: 'ls-hero-banner__star' %}{% endfor %}</span>
                      <span class="ls-hero-banner__rating-text">{% if block.settings.rating_value != blank %}<b>{{ block.settings.rating_value | escape }}</b>{% endif %}{% if block.settings.rating_value != blank and block.settings.rating_text != blank %} {% endif %}{% if block.settings.rating_text != blank %}{{ block.settings.rating_text | escape }}{% endif %}</span>
                    </div>
                  {% endif %}
                </div>
                {% if block.settings.floating_cta_title != blank %}
                  <a href="{{ block.settings.floating_cta_link }}" class="ls-hero-banner__floating-cta">{{ block.settings.floating_cta_title | escape }}</a>
                {% endif %}
              </div>
            </div>
          </media-carousel-slide>
        {% endfor %}
      {%- endcapture -%}

      <media-carousel-preview-image>{{ preview_image }}</media-carousel-preview-image>
      <media-carousel-slider class="swiper">
        <media-carousel-wrapper class="swiper-wrapper">
          {{ slides }}
        </media-carousel-wrapper>
      </media-carousel-slider>

      {%- if section.blocks.size > 1 -%}
        <div class="home-carousel__nav ls-hero-banner__nav">
          {%- unless section.settings.hide_nav_arrows -%}
            <media-carousel-navigation class="media-carousel__navigation">
              <button type="button" class="media-carousel__arrow media-carousel__arrow--prev js-carousel-prev">
                {%- render 'icons-theme', icon: 'chevron', additional_classes: 'icon--left' -%}
              </button>
              <button type="button" class="media-carousel__arrow media-carousel__arrow--next js-carousel-next">
                {%- render 'icons-theme', icon: 'chevron' -%}
              </button>
            </media-carousel-navigation>
          {%- endunless -%}
          <media-carousel-pagination class="media-carousel__pagination swiper-pagination js-carousel-pagination"></media-carousel-pagination>
        </div>
      {%- endif -%}
    </media-carousel>

    {% if section.settings.slideshow_width == 'contained' %}</div>{% endif %}
  </section>
{% endif %}

{% if section.blocks.size == 0 %}
  <div class="placeholder-noblocks">
    {{ 'homepage.onboarding.no_content' | t }}
  </div>
{% endif %}

{% schema %}
{
  "name": "LS Hero banner",
  "class": "js-section__ls-hero-banner",
  "max_blocks": 5,
  "settings": [
    {
      "type": "header",
      "content": "Height and width"
    },
    {
      "type": "select",
      "id": "slideshow_height",
      "label": "Section height",
      "default": "large",
      "options": [
        { "label": "Small", "value": "small" },
        { "label": "Medium", "value": "medium" },
        { "label": "Large", "value": "large" },
        { "label": "Full screen", "value": "full-screen" }
      ]
    },
    {
      "type": "select",
      "id": "slideshow_width",
      "label": "Section width",
      "default": "full",
      "options": [
        { "label": "Contained", "value": "contained" },
        { "label": "Full", "value": "full" }
      ]
    },
    {
      "type": "header",
      "content": "Carousel"
    },
    {
      "type": "checkbox",
      "id": "hide_nav_arrows",
      "label": "Hide navigation arrows",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto rotate carousel",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Change slides every",
      "unit": "sec",
      "min": 5,
      "max": 10,
      "step": 1,
      "default": 8
    },
    {
      "type": "header",
      "content": "Margin"
    },
    {
      "type": "checkbox",
      "id": "section_bottom_margin",
      "label": "Reduce bottom margin",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop image",
          "info": "2200px width recommended."
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile image",
          "info": "Optional. Portrait ratio recommended."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Headline",
          "default": "YARDS BUILT RIGHT FOR CHICAGOLAND HOMES"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Body text",
          "default": "<p>From fences to playsets, basketball hoops, and trampolines — we help families build outdoor spaces done right, by a local team you can trust.</p>"
        },
        {
          "type": "header",
          "content": "Primary button"
        },
        {
          "type": "text",
          "id": "link_title",
          "label": "Label",
          "default": "Get a Free Fence Quote"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "arrow_direction",
          "label": "Button arrow direction",
          "default": "arrow-right",
          "options": [
            { "value": "arrow-right", "label": "Right" },
            { "value": "arrow-up-right", "label": "Up-right" },
            { "value": "arrow-up", "label": "Up" },
            { "value": "arrow-down", "label": "Down" },
            { "value": "chevron-right", "label": "Chevron" }
          ]
        },
        {
          "type": "header",
          "content": "Secondary button"
        },
        {
          "type": "text",
          "id": "link_title_2",
          "label": "Label",
          "default": "Browse Fences"
        },
        {
          "type": "url",
          "id": "link_2",
          "label": "Link"
        },
        {
          "type": "header",
          "content": "Floating CTA (bottom right)"
        },
        {
          "type": "text",
          "id": "floating_cta_title",
          "label": "Label",
          "default": "Get a Free Quote"
        },
        {
          "type": "url",
          "id": "floating_cta_link",
          "label": "Link"
        },
        {
          "type": "header",
          "content": "Rating / trust"
        },
        {
          "type": "text",
          "id": "rating_value",
          "label": "Rating value",
          "default": "4.9/5.0"
        },
        {
          "type": "text",
          "id": "rating_text",
          "label": "Rating description",
          "default": "Trusted by Backyard experts"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LS Hero banner",
      "settings": {
        "autoplay": true,
        "autoplay_speed": 8
      },
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "title": "YARDS BUILT RIGHT FOR CHICAGOLAND HOMES",
            "text": "<p>From fences to playsets, basketball hoops, and trampolines — we help families build outdoor spaces done right, by a local team you can trust.</p>",
            "link_title": "Get a Free Fence Quote",
            "link_title_2": "Browse Fences",
            "floating_cta_title": "Get a Free Quote",
            "rating_value": "4.9/5.0",
            "rating_text": "Trusted by Backyard experts"
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["*"],
    "groups": ["footer"]
  }
}
{% endschema %}

