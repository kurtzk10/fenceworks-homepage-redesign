{% if section.index > 2 or section.location == 'footer' %}
  <link
    rel="stylesheet"
    href="{{ 'section-ls-basketball-hoop-services.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
  <noscript>
    {{ 'section-ls-basketball-hoop-services.css' | asset_url | stylesheet_tag }}
  </noscript>
{% else %}
  {{ 'section-ls-basketball-hoop-services.css' | asset_url | stylesheet_tag }}
{% endif %}

<section
  class="
    section
    section--padded
    section--ls-basketball-hoop-services
    section--{{ section.id }}
    {% if section.settings.section_bottom_margin %}section--mb-0{% endif %}
  "
  data-section-id="{{ section.id }}"
  data-section-type="ls-basketball-hoop-services"
  style="
    --space-top: {{ section.settings.padding_top }}px;
    --space-bottom: {{ section.settings.padding_bottom }}px;
    --lsbhs-bg: {{ section.settings.card_bg }};
    --lsbhs-heading-color: {{ section.settings.heading_color }};
    --lsbhs-body-color: {{ section.settings.body_color }};
    --lsbhs-support-color: {{ section.settings.support_color }};
    --lsbhs-btn-border: {{ section.settings.button_border_color }};
    --lsbhs-btn-text: {{ section.settings.button_text_color }};
    --lsbhs-radius: {{ section.settings.card_radius }}px;
  "
>
  <div class="lsbhs__outer">
    <div class="container container--{{ section.settings.section_width }}">
      <div class="lsbhs__card">
        {%- if section.settings.heading != blank -%}
          <h2 class="lsbhs__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.body_text != blank -%}
          <div class="lsbhs__body rte">{{ section.settings.body_text }}</div>
        {%- endif -%}
        {%- if section.settings.support_text != blank -%}
          <p class="lsbhs__support">{{ section.settings.support_text | escape }}</p>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a
            href="{{ section.settings.button_link | default: '#' }}"
            class="lsbhs__btn"
          >
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "LS Hoop Services",
  "class": "js-section__ls-basketball-hoop-services",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "COMPLETE BASKETBALL HOOP SERVICES"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>We offer professional installation (residential and commercial), relocation, removal, and maintenance services for all basketball hoop systems. Our experienced team ensures safe, proper setup for years of reliable performance.</p>"
    },
    {
      "type": "text",
      "id": "support_text",
      "label": "Support text",
      "default": "Need Help? Contact Us"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Contact Fenceworks"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "default": "large",
      "options": [
        { "label": "Default", "value": "large" },
        { "label": "Narrow", "value": "small" },
        { "label": "Wide", "value": "full" }
      ]
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "unit": "px",
      "min": 0,
      "max": 48,
      "step": 2,
      "default": 40
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#12191d"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "support_color",
      "label": "Support text",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Button border",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Padding and margin"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "unit": "px",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "unit": "px",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "checkbox",
      "id": "section_bottom_margin",
      "label": "Reduce bottom margin",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "LS Hoop Services"
    }
  ],
  "enabled_on": {
    "templates": ["*"]
  }
}
{% endschema %}
