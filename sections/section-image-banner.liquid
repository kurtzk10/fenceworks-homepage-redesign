{% if section.index > 2 or section.location == 'footer' %}
  <link
    rel="stylesheet"
    href="{{ 'section-image-banner.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
  <noscript>
    {{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
  </noscript>
{% else %}
  {{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{% endif %}

<section
  class="
    section
    section--{{ section.id }}
    section--{{ section.settings.section_width }}
    {% if section.settings.section_bottom_margin %}
      {% if section.settings.section_width == 'contained' %}
        section--mb-m
      {% else %}
        section--mb-0
      {% endif %}
    {% endif %}
  "
  data-section-id="{{ section.id }}"
  data-section-type="image-banner"
>
  {% if section.settings.section_width == 'contained' %}<div class="container container--large">{% endif %}

  <div
    class="
      image-banner-simple
      image-banner-simple--{{ section.settings.section_width }}
      {% if section.settings.border_radius %}image-banner-simple--radius{% endif %}
      js-animate-single
    "
  >
    {% if section.settings.image_desktop != blank %}
      {%- liquid
        assign loading = 'lazy'
        if section.location == 'template' and section.index == 1
          assign loading = 'eager'
        endif

        assign sizes = '100vw'
        if section.settings.section_width == 'contained'
          assign sizes = '(min-width: 1400px) 1320px, calc(100vw - 60px)'
        endif

        assign image_desktop = section.settings.image_desktop
        assign image_mobile = section.settings.image_mobile
        assign image_height_desktop = 600 | divided_by: image_desktop.aspect_ratio | round
      -%}
      <picture>
        {% if image_mobile != blank %}
          <source
            srcset="{% render 'bgset', image: image_mobile %}"
            media="(max-width: 980px)"
          >
        {% endif %}
        <source
          srcset="{% render 'bgset', image: image_desktop %}"
          media="(min-width: 981px)"
        >
        {%- render 'image-skeleton',
          alt: image_desktop.alt,
          width: 600,
          height: image_height_desktop
        -%}
        <img
          class="image-banner-simple__img"
          src="{{ image_desktop | image_url: width: 1200 }}"
          width="1200"
          height="{{ 1200 | divided_by: image_desktop.aspect_ratio | round }}"
          alt="{{ image_desktop.alt | escape }}"
          loading="{{ loading }}"
          fetchpriority="{% if section.location == 'template' and section.index == 1 %}high{% else %}auto{% endif %}"
          sizes="{{ sizes }}"
          style="
            --image-position: {{ image_desktop.presentation.focal_point }};
            --image-position-mobile: {% if image_mobile != blank %}{{ image_mobile.presentation.focal_point }}{% else %}{{ image_desktop.presentation.focal_point }}{% endif %};
          "
        >
      </picture>
    {% else %}
      <div class="image-banner-simple__placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {% endif %}
  </div>

  {% if section.settings.section_width == 'contained' %}</div>{% endif %}
</section>

{% schema %}
{
  "name": "Image banner",
  "class": "js-section__image-banner",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop image",
      "info": "Recommended: 2200px width or wider for full-width display."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image",
      "info": "Optional. Alternative image for mobile. 1200px width and portrait ratio work well."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "default": "full",
      "options": [
        {
          "label": "Contained",
          "value": "contained"
        },
        {
          "label": "Full",
          "value": "full"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "border_radius",
      "label": "Rounded corners",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "section_bottom_margin",
      "label": "Bottom margin",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Image banner"
    }
  ]
}
{% endschema %}
