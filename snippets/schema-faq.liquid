{% comment %}
  FAQPage JSON-LD schema. Expects: section (the FAQ section object).
  Outputs schema only when the section has at least one article (FAQ) block.
{% endcomment %}
{%- assign faq_blocks = section.blocks | where: 'type', 'article' -%}
{%- if faq_blocks.size > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in faq_blocks -%}
    {
      "@type": "Question",
      "name": {{ block.settings.title | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ block.settings.text | strip_html | strip_newlines | strip | json }}
      }
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}
