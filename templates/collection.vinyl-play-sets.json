        "custom_liquid": "<style>\n.shopify-section-group-footer-group.js-section__newsletter, .shopify-section-group-footer-group.js-section__custom-content {\n    display: none;\n}\ndiv#main{\nmargin-top: 0;\n}\n\n\nh2 {\n    letter-spacing: 1.9px;\n}\n\n.usp-icons__header {\n    max-width: 570px!important;\n}\n\n.usp-icons__desc {\n    letter-spacing: 0.4px;\n}\n</style>\n<script>\ndocument.addEventListener('DOMContentLoaded', function () {\n\n\n  const OFFSET = 100; // adjust to your header height\nconst OFFSET_MOBILE = 65; // adjust to your header height\n  const anchorLinks = document.querySelectorAll('a[href*=\"#\"]:not([href=\"#\"])');\n\n  anchorLinks.forEach(link => {\n    link.addEventListener('click', function (e) {\n      const targetId = this.getAttribute('href');\n      const targetEl = document.querySelector(targetId);\n\n      if (!targetEl) return;\n\n      e.preventDefault();\n\n      const elementPosition = targetEl.getBoundingClientRect().top + window.pageYOffset;\n      \nif(window.innerWidth < 768){\nvar offsetPosition = elementPosition - OFFSET_MOBILE;\n}\nelse{\nvar offsetPosition = elementPosition - OFFSET;\n}\n\n      window.scrollTo({\n        top: offsetPosition,\n        behavior: 'smooth'\n      });\n    });\n  });\n});\n</script>"
