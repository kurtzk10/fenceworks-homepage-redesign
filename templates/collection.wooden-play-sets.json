    "section_rich_text_6DTfWy": {
      "type": "section-rich-text",
      "name": "Rich text",
      "settings": {
        "section_title": "Our Services at Fenceworks",
        "text": "<p>At Fenceworks, we pride ourselves on customer service. When you order from an online retailer, you get no guarantee in terms of quality, size, installation, and other factors. As a family-owned local business, you get a personal service to ensure the right solution for your property. </p><p>We’ll visit your property (or you can visit our Northbrook showroom), assess your needs, and make tailored recommendations. What’s more, our experienced and knowledgeable professionals will install the equipment and provide advice on care and maintenance. We’ve been a proud member of the community since 1967, and we look forward to helping your business or family next! </p>",
        "section_width": "tiny",
        "padding_top": 0,
        "padding_bottom": 0,
        "section_bottom_margin": false
      }
    },
