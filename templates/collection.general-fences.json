          }
        },
        "image_U8NFXr": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/Wood_Fence_2.png",
            "video": "",
            "video_button_color": "primary",
            "title": "Fenceworks Value.",
            "desc": "<p>When you call for a Free in-home Fence estimate we will present photos and descriptions of selected fences, survey your property, discuss with you your fencing needs, and provide you with a complete fence estimate along with a choice of convenient installation dates. We custom design and install every fence on site. Fenceworks has earned the Highest A+ Rating with the Better Business Bureau. We are among the most recommended Chicago fence contractors, serving the Chicago and Chicago northern and North Shore suburban communities.</p>",
            "horizontal_align": "left",
            "link_title": "",
            "link": "shopify://pages/free-estimate",
