        },
        "text_dXart3": {
          "type": "text",
          "settings": {
            "media": "stars-brand",
            "svg-code": "",
            "image_round": true,
            "text": "<p>When it comes to a Fence instillation.. there is no better company in the north shore/chicago that I would recommend more than Fenceworks. They truly care about each customer like their family. I was informed every step of the way, true transparency throughout. Pricing was fair and competitive, and the craftsmanship was truly amazing. I look forward to buying a playground, trampoline, and basketball hoop this spring to wrap up all my home improvement projects in the future!</p>",
            "name": "Adrish Saha",
            "source": "Google Reviews"
          }
        },
        "text_YJg9NU": {
          "type": "text",
