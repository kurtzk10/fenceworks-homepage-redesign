      "type": "section-ls-faq",
      "blocks": {
        "faq_item_afUnc6": {
          "type": "faq_item",
          "settings": {
            "question": "Do you offer free estimates?",
            "answer": "<p>Yes. All fence estimates are free and done on-site to ensure accurate pricing and a custom solution.</p>"
          }
        },
        "faq_item_Mmj8mP": {
          "type": "faq_item",
          "settings": {
            "question": "What types of fences do you install?",
            "answer": "<p>We install wood, vinyl (PVC), composite, aluminum, and chain link fences for residential properties.</p>"
          }
        },
        "faq_item_iYgD47": {
          "type": "faq_item",
          "settings": {
            "question": "How long does installation take?",
            "answer": "<p>Most fence installations are completed in one to two days, depending on size, material, and site conditions.</p>"
          }
        },
        "faq_item_XkNHNr": {
          "type": "faq_item",
          "settings": {
            "question": "Do you build fences on-site or use pre-made panels?",
            "answer": "<p>Every fence is built board-by-board on-site for a stronger structure and a cleaner, custom fit.</p>"
          }
        },
        "faq_item_ndfKiJ": {
          "type": "faq_item",
          "settings": {
            "question": "Are you licensed and insured?",
            "answer": "<p>Yes. Fenceworks is fully licensed and insured for your peace of mind.</p>"
          }
        },
        "faq_item_hkkTtT": {
          "type": "faq_item",
          "settings": {
            "question": "Do you offer warranties?",
            "answer": "<p>Yes. We provide a lifetime limited labor warranty and manufacturer warranties on materials.</p>"
          }
        },
        "faq_item_pFLxQB": {
          "type": "faq_item",
          "settings": {
            "question": "What areas do you serve?",
            "answer": "<p>We serve Chicagoland and surrounding suburbs. Contact us to confirm availability in your area.</p>"
          }
        },
