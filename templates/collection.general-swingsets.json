    "section_image_with_text_GaUgmg": {
      "type": "section-image-with-text",
      "blocks": {
        "image_qwfmGh": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/Playset_Installation.jpg",
            "video": "",
            "video_button_color": "primary",
            "title": "Why Playsets in Chicago Are Timeless for All",
            "desc": "<p>All around the country, all around the world, you’ll find swing sets and playsets in backyards and local play areas. Even in a world of technology, children love to spend their time swinging and climbing. At Fenceworks, we’ve watched the world change since launching in 1967, but one thing that hasn’t changed is the smiles of children when they see a fun-looking playset. <br/><br/></p>",
            "horizontal_align": "left",
            "link_title": "",
            "link": "",
            "bg_color_block": "rgba(0,0,0,0)",
            "bg_color_content": "rgba(0,0,0,0)",
            "color_text": "rgba(0,0,0,0)",
            "text_heading_color": true,
            "text_border_color": true
          }
        }
      },
      "block_order": [
